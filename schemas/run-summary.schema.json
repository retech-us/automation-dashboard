{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://retech-us.github.io/automation-dashboard/schemas/run-summary.schema.json",
  "title": "Automation Run Summary",
  "description": "Standardized test run summary for unified automation dashboard",
  "type": "object",
  "required": [
    "schemaVersion",
    "repo",
    "status",
    "summary",
    "reportUrl"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "repo": { "type": "string", "enum": ["web", "mobile", "api"] },
    "repoName": { "type": "string" },
    "repository": { "type": "string" },
    "runId": { "type": "string" },
    "runNumber": { "type": "integer" },
    "workflow": { "type": "string" },
    "branch": { "type": "string" },
    "commit": { "type": "string" },
    "environment": { "type": "string" },
    "suite": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "failed", "unknown"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "broken": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "reportUrl": { "type": "string", "format": "uri" },
    "ciRunUrl": { "type": "string", "format": "uri" },
    "topFailures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "category", "reason"],
        "properties": {
          "name": { "type": "string" },
          "fullName": { "type": "string" },
          "status": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["login", "locator", "timeout", "api", "data", "environment", "assertion", "unknown"]
          },
          "reason": { "type": "string" },
          "feature": { "type": "string" }
        }
      }
    },
    "failureCategories": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "summary": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "passed": { "type": "integer" },
              "failed": { "type": "integer" },
              "skipped": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
